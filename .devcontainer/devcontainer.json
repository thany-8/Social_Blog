{
  "name": "SocialBlog",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "postAttachCommand": {
    "Run SocialBlog": "flask --app app.py run --host 0.0.0.0 --port 5000"
  },
  "forwardPorts": [5000],
  "portsAttributes": {
    "5000": {
      "label": "SocialBlog",
      "onAutoForward": "openBrowser"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python"]
    }
  }
}
