# Copy to .env and adjust. The app reads these from the environment
# (e.g. `export $(grep -v '^#' .env | xargs)` or set them in your shell/host).

# Flask session & CSRF secret — use a long random string.
SECRET_KEY=change-me-to-a-long-random-string

# Optional: enables Google Perspective API comment moderation.
# Get a free key: https://developers.perspectiveapi.com/s/docs-get-started
PERSPECTIVE_API_KEY=

# Optional: set to 0 to disable the offline keyword screen that runs when no
# Perspective key is configured (default: enabled).
MODERATION_OFFLINE_FALLBACK=1

# Optional: override the database (defaults to socialblog/data.sqlite).
# DATABASE_URL=sqlite:////absolute/path/to/data.sqlite
